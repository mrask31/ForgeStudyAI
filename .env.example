# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Redis Configuration (optional - graceful fallback if not configured)
REDIS_URL=redis://localhost:6379

# Dual AI Orchestration - API Keys
# Get your Anthropic API key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=your-anthropic-api-key

# Get your Google AI API key from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key

# Stripe Configuration (for payments)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=your-stripe-publishable-key
STRIPE_SECRET_KEY=your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=your-stripe-webhook-secret

# OpenAI Configuration (if using OpenAI features)
OPENAI_API_KEY=your-openai-api-key

# LMS Token Encryption (required for Canvas/Google Classroom connections)
# Must be at least 32 characters. Generate with: openssl rand -base64 48
LMS_ENCRYPTION_KEY=your-lms-encryption-key-minimum-32-characters

# Google Classroom OAuth (required for Google Classroom connections)
GOOGLE_OAUTH_CLIENT_ID=your-google-client-id
GOOGLE_OAUTH_CLIENT_SECRET=your-google-client-secret
